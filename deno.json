{
	"name": "gumbox",
	"version": "0.1.0",
	"exports": {
		".": "./src/index.ts",
		"./cli": "./src/cli/gumbox.ts"
	},
	"nodeModulesDir": "auto",
	"imports": {
		"mitt": "npm:mitt@^3.0.1",
		"pathe": "npm:pathe@^2.0.3",
		"tinyglobby": "npm:tinyglobby@^0.2.17",
		"@types/node": "npm:@types/node@24.12.2",
		"typescript": "npm:typescript@5.9.3",
		"vite": "npm:vite@8.0.16",
		"vite-plus": "npm:vite-plus@0.1.20"
	},
	"tasks": {
		"test": "deno task manifest && vp test",
		"dev": "deno task manifest && vp test watch",
		"test:watch": "deno task manifest && vp test watch",
		"build": "deno task manifest && vp pack",
		"cli": "deno run -A ./src/cli/gumbox.ts",
		"manifest": "deno run --allow-read=. --allow-write=. ./scripts/generate-package-json.ts",
		"release": "deno run -A ./scripts/release.ts",
		"fmt": "vp fmt",
		"fmt:check": "vp fmt --check",
		"lint": "vp lint",
		"typecheck": "tsc --noEmit",
		"check": "deno task manifest && vp check"
	}
}
